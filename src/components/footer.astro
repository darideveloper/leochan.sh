---
const currentYear = new Date().getFullYear();
---

<footer class="w-full bg-[var(--background)] py-12 md:py-16 border-t border-[var(--white-icon-tr)]">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex flex-col md:flex-row justify-between items-center md:items-start gap-10">
      <!-- Left: Logo & Title -->
      <div class="flex items-center space-x-4">
        <a href="#home" class="flex items-center gap-3 transition-transform hover:scale-105" aria-label="NEKOCORP // L.A. Home">
          <img 
            src="/logo-leochan.webp" 
            alt="NEKOCORP Logo" 
            class="h-8 md:h-10 w-auto object-contain brightness-0 invert opacity-80"
            loading="lazy"
          />
          <span class="font-vcr text-2xl md:text-3xl text-[var(--white)] tracking-tighter">NEKOCORP // L.A.</span>
        </a>
      </div>

      <!-- Right: Status & Copyright -->
      <div class="flex flex-col items-center md:items-end text-center md:text-right space-y-4">
        <div class="space-y-2">
          <p class="text-[var(--white-icon)] text-xs font-vcr tracking-widest uppercase">
            System Status: <span class="text-green-500">SECURE</span> | Encryption: AES-256 | Protocol: HTTPS
          </p>
          <p class="text-sm text-[var(--white-icon)]">
            Copyright © {currentYear} <a href="https://github.com/nekocorp" class="hover:text-[var(--white)] transition-colors">Léonard-Anton</a>. Tous droits réservés.
          </p>
        </div>
      </div>
    </div>
  </div>
</footer>
