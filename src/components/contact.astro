---
import TypingText from "../React/TypingText.tsx";
---

<section id="contact" class="w-full bg-[var(--background)] py-12 md:py-24 border-y border-[var(--white-icon-tr)] mt-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-sm md:text-lg text-[var(--sec)] mb-2 shiny-sec">
      <TypingText client:visible text="[ INCOMING_TRANSMISSION ]" />
    </h2>
    <h3 class="text-2xl md:text-5xl font-medium text-[var(--white)] mb-6">
      <TypingText client:visible text="[04] _ESTABLISH_CONNECTION" />
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="text-[var(--white-icon)]">
        <p class="mb-4">
          Have a question, an infrastructure proposal, or a security audit in mind? Feel free to reach out.
        </p>
        <div class="flex items-center gap-2 font-mono">
          <span>Location:</span>
          <span class="text-[var(--white)]">France / TotalEnergies TGITS</span>
        </div>
      </div>

      <div>
        <form
          id="contact-form"
          action="https://formspree.io/f/leonard_contact_placeholder"
          method="POST"
          class="flex flex-col gap-4"
        >
          <div class="cyber-glass rounded-lg focus-within:ring-2 focus-within:ring-[var(--sec)] transition-all overflow-hidden">
            <input
              type="text"
              name="from_name"
              placeholder="Name"
              aria-label="Name"
              required
              class="px-4 py-2 bg-transparent w-full h-full text-[var(--white)] border-none outline-none"
            />
          </div>
          <div class="cyber-glass rounded-lg focus-within:ring-2 focus-within:ring-[var(--sec)] transition-all overflow-hidden">
            <input
              type="email"
              name="reply_to"
              placeholder="Email"
              aria-label="Email"
              required
              class="px-4 py-2 bg-transparent w-full h-full text-[var(--white)] border-none outline-none"
            />
          </div>
          <div class="cyber-glass rounded-lg focus-within:ring-2 focus-within:ring-[var(--sec)] transition-all overflow-hidden">
            <textarea
              name="message"
              placeholder="Message"
              aria-label="Message"
              rows="6"
              required
              class="px-4 py-2 bg-transparent w-full h-full text-[var(--white)] border-none outline-none resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class="px-4 py-2 bg-[var(--white-icon-tr)] text-[var(--white)] rounded-lg opacity-60 transition-opacity border border-[var(--white-icon-tr)] hover:opacity-100 hover:bg-[var(--white-icon-tr)] font-vcr"
          >
            ssh leonard+leochan.sh@nekocorp.fr
          </button>
        </form>
        <div
          id="form-message"
          class="hidden justify-center items-center mt-4 text-[var(--white)] text-lg"
        >
          ✅ Thank you for your message!
        </div>
      </div>
    </div>
  </div>
</section>

<script type="module" is:inline>
  const form = document.getElementById("contact-form");
  const formMessage = document.getElementById("form-message");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" },
      });
      if (response.ok) {
        form.reset();
        form.style.display = "none";
        formMessage.classList.remove("hidden");
      } else {
        const data = await response.json();
        console.error("Error response:", data);
        alert("A problem occurred while sending your message.");
      }
    } catch (error) {
      console.error("Error:", error);
      alert("A problem occurred while sending your message.");
    }
  });
</script>
