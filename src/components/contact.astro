---
import clsx from 'clsx';
import TypingText from "../React/TypingText.tsx";

const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8000/api';
---

<section id="contact" class="w-full bg-[var(--background)] py-12 md:py-24 border-y border-[var(--white-icon-tr)] mt-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-sm md:text-lg text-[var(--sec)] mb-2 shiny-sec">
      <TypingText client:visible text="[ INCOMING_TRANSMISSION ]" />
    </h2>
    <h3 class="text-2xl md:text-5xl font-medium text-[var(--white)] mb-6">
      <TypingText client:visible text="[04] _ESTABLISH_CONNECTION" />
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="text-[var(--white-icon)]">
        <p class="mb-4">
          Have a question, an infrastructure proposal, or a security audit in mind? Feel free to reach out.
        </p>
        <div class="flex items-center gap-2 font-mono">
          <span>Location:</span>
          <span class="text-[var(--white)]">France / TotalEnergies TGITS</span>
        </div>
      </div>

      <div>
        <form
          id="contact-form"
          data-api-url={`${apiUrl}/contact/`}
          method="POST"
          class="flex flex-col gap-4"
        >
          <div class={clsx("cyber-glass rounded-lg focus-within:ring-2 focus-within:ring-[var(--sec)] transition-all overflow-hidden")}>
            <input
              type="text"
              name="name"
              placeholder="Name"
              aria-label="Name"
              required
              class="px-4 py-2 bg-transparent w-full h-full text-[var(--white)] border-none outline-none"
            />
          </div>
          <div class={clsx("cyber-glass rounded-lg focus-within:ring-2 focus-within:ring-[var(--sec)] transition-all overflow-hidden")}>
            <input
              type="email"
              name="email"
              placeholder="Email"
              aria-label="Email"
              required
              class="px-4 py-2 bg-transparent w-full h-full text-[var(--white)] border-none outline-none"
            />
          </div>
          <div class={clsx("cyber-glass rounded-lg focus-within:ring-2 focus-within:ring-[var(--sec)] transition-all overflow-hidden")}>
            <textarea
              name="message"
              placeholder="Message"
              aria-label="Message"
              rows="6"
              required
              class="px-4 py-2 bg-transparent w-full h-full text-[var(--white)] border-none outline-none resize-none"
            ></textarea>
          </div>
          <button
            type="submit"
            class={clsx(
              "px-4 py-2 bg-[var(--white-icon-tr)] text-[var(--white)] rounded-lg opacity-60 transition-opacity border border-[var(--white-icon-tr)] hover:opacity-100 hover:bg-[var(--white-icon-tr)] font-vcr flex items-center justify-center gap-2 disabled:cursor-not-allowed disabled:opacity-40"
            )}
          >
            <span>ssh leonard+leochan.sh@nekocorp.fr</span>
            <div id="form-spinner" class="hidden w-4 h-4 border-2 border-[var(--white)] border-t-transparent rounded-full animate-spin"></div>
          </button>
        </form>
        <div
          id="form-message"
          class="hidden justify-center items-center mt-4 text-[var(--white)] text-lg"
        >
          ✅ Thank you for your message!
        </div>
      </div>
    </div>
  </div>
</section>

<script type="module">
  const form = document.getElementById("contact-form");
  const formMessage = document.getElementById("form-message");
  const formSpinner = document.getElementById("form-spinner");
  const submitBtn = form.querySelector('button[type="submit"]');

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const apiUrl = form.dataset.apiUrl;
    const formData = new FormData(form);
    const payload = Object.fromEntries(formData.entries());

    // UI state: Loading
    submitBtn.disabled = true;
    formSpinner.classList.remove("hidden");

    try {
      const response = await fetch(apiUrl, {
        method: "POST",
        body: JSON.stringify(payload),
        headers: { 
          "Content-Type": "application/json",
          "Accept": "application/json" 
        },
      });
      
      if (response.ok) {
        form.reset();
        form.style.display = "none";
        formMessage.classList.remove("hidden");
      } else {
        const data = await response.json();
        console.error("Error response:", data);
        
        let errorMessage = "A problem occurred while sending your message.";
        if (data && typeof data === 'object') {
          const firstError = Object.values(data)[0];
          if (Array.isArray(firstError)) {
            errorMessage = firstError[0];
          }
        }
        alert(errorMessage);
      }
    } catch (error) {
      console.error("Error:", error);
      alert("ssh connection timed out. Please check your network and try again.");
    } finally {
      // Re-enable UI state
      submitBtn.disabled = false;
      formSpinner.classList.add("hidden");
    }
  });
</script>
