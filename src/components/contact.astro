---
import TypingText from "../React/TypingText.tsx";
---

<section id="contact" class="w-full bg-[var(--background)] py-12 md:py-24 border-y border-[var(--white-icon-tr)] mt-12">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <h2 class="text-lg text-[var(--sec)] mb-2 shiny-sec">
      <TypingText client:visible text="[ INCOMING_TRANSMISSION ]" />
    </h2>
    <h3 class="text-4xl md:text-5xl font-medium text-[var(--white)] mb-6">
      <TypingText client:visible text="[05] _ESTABLISH_CONNECTION" />
    </h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      <div class="text-[var(--white-icon)]">
        <p class="mb-4">
          Vous avez une question, une proposition d'infrastructure ou un audit de sécurité en tête ? N'hésitez pas à me contacter.
        </p>
        <div class="flex items-center gap-2">
          <span>Lieu :</span>
          <span class="text-[var(--white)]">France / TotalEnergies TGITS</span>
        </div>
      </div>

      <div>
        <form
          id="contact-form"
          action="https://formspree.io/f/leonard_contact_placeholder"
          method="POST"
          class="flex flex-col gap-4"
        >
          <input
            type="text"
            name="from_name"
            placeholder="Nom"
            aria-label="Nom"
            required
            class="px-4 py-2 bg-white/5 backdrop-blur-md text-[var(--white)] border border-white/10 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)] transition-all hover:bg-white/10"
          />
          <input
            type="email"
            name="reply_to"
            placeholder="E-mail"
            aria-label="E-mail"
            required
            class="px-4 py-2 bg-white/5 backdrop-blur-md text-[var(--white)] border border-white/10 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)] transition-all hover:bg-white/10"
          />
          <textarea
            name="message"
            placeholder="Message"
            aria-label="Message"
            rows="6"
            required
            class="px-4 py-2 bg-white/5 backdrop-blur-md text-[var(--white)] border border-white/10 rounded-lg focus:outline-none focus:ring-2 focus:ring-[var(--sec)] resize-none transition-all hover:bg-white/10"
          ></textarea>
          <button
            type="submit"
            class="px-4 py-2 bg-[var(--white-icon-tr)] text-[var(--white)] rounded-lg opacity-60 transition-opacity border border-[var(--white-icon-tr)] hover:opacity-100 hover:bg-[var(--white-icon-tr)] font-vcr"
          >
            ssh contact@nekocorp.me
          </button>
        </form>
        <div
          id="form-message"
          class="hidden justify-center items-center mt-4 text-[var(--white)] text-lg"
        >
          ✅ Merci pour votre message !
        </div>
      </div>
    </div>
  </div>
</section>

<script type="module" is:inline>
  const form = document.getElementById("contact-form");
  const formMessage = document.getElementById("form-message");

  form.addEventListener("submit", async (e) => {
    e.preventDefault();
    const formData = new FormData(form);

    try {
      const response = await fetch(form.action, {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" },
      });
      if (response.ok) {
        form.reset();
        form.style.display = "none";
        formMessage.classList.remove("hidden");
      } else {
        const data = await response.json();
        console.error("Error response:", data);
        alert("Un problème est survenu lors de l'envoi de votre message.");
      }
    } catch (error) {
      console.error("Error:", error);
      alert("Un problème est survenu lors de l'envoi de votre message.");
    }
  });
</script>
