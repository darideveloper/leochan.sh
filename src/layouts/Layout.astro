---
interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <title>{title} | Cybersecurity & Infrastructure Engineer</title>
    <meta
      name="description"
      content="Portfolio of Léonard-Anton, an IT & Cybersecurity student specializing in Zero-Trust architectures, infrastructure automation, and enterprise-grade systems. Explore the Nekocorp homelab and professional automation workflows at TotalEnergies."
    />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="canonical" href="https://leonardanton.me/" />

    <link
      rel="preload"
      href="/fonts/montserrat-latin-wght-normal.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="/fonts/VCR_OSD_MONO.ttf"
      as="font"
      type="font/ttf"
      crossorigin="anonymous"
    />

    <meta
      property="og:title"
      content="Léonard-Anton | Cyber-Glass Portfolio"
    />
    <meta
      property="og:description"
      content="Exploring the intersection of Zero-Trust security and high-performance infrastructure. Witness the Nekocorp ecosystem."
    />
    <meta
      property="og:image"
      content="https://leonardanton.me/og.image.png"
    />
    <meta property="og:url" content="https://leonardanton.me" />
    <meta property="og:type" content="website" />
    <meta
      property="og:site_name"
      content="NEKOCORP // L.A. Portfolio"
    />

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Léonard-Anton",
        "alternateName": "L.A.",
        "url": "https://leonardanton.me",
        "image": "https://leonardanton.me/og.image.png",
        "sameAs": [
          "https://github.com/nekocorp",
          "https://linkedin.com/in/leonardanton-infra"
        ],
        "jobTitle": "Cybersecurity & Infrastructure Engineer",
        "description": "Engineering student specializing in Zero-Trust architectures and infrastructure automation at TotalEnergies."
      }
    </script>

    <script is:inline>
      const originalTitle = document.title;
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) {
          document.title = "[DISCONNECTED] Léonard-Anton";
        } else {
          document.title = originalTitle;
        }
      });
    </script>
  </head>
  <body class="bg-[--background]">
    <slot />
  </body>
</html>

<style is:global>
  @font-face {
    font-family: "Montserrat Variable";
    src: url("/fonts/montserrat-latin-wght-normal.woff2")
      format("woff2-variations");
    font-weight: 100 900;
    font-style: normal;
    font-display: swap;
  }

  @font-face {
    font-family: "VCR OSD MONO";
    src: url("/fonts/VCR_OSD_MONO.ttf") format("truetype");
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  :root {
    --background: #06020C;
    --surface: #14101A9C;
    --primary: #C92FFF;
    --primary-light: #E0A3FF;
    --secondary: #5D15D9;
    --tertiary: #FF1493;
    --foreground: #EFEFEF;
    --muted: #FFFFFF80;
    --border-subtle: #FFFFFF15;
    --selection-bg: #C92FFF;
    --scrollbar-track: #100A1A;
    --scrollbar-thumb: #5D15D9;

    /* Maintain compatibility with variables that might still be used elsewhere */
    --sec: var(--primary);
    --white: var(--foreground);
    --white-icon: var(--muted);
    --white-icon-tr: var(--border-subtle);
  }

  * {
    font-family:
      "Montserrat Variable",
      -apple-system,
      system-ui,
      sans-serif;
    box-sizing: border-box;
    padding: 0;
    margin: 0;
  }

  h1,
  h2,
  h3,
  h4,
  h5,
  h6 {
    font-family: "VCR OSD MONO", monospace;
  }

  *::selection {
    background-color: var(--selection-bg);
    color: var(--foreground);
  }

  /* Scrollbar styles */

  ::-webkit-scrollbar {
    width: 15px;
  }

  ::-webkit-scrollbar-track {
    background: var(--scrollbar-track);
    border-radius: 30px;
  }

  ::-webkit-scrollbar-thumb {
    background: var(--scrollbar-thumb);
    border-radius: 10px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: var(--primary);
  }

  /* Scrollbar styles for Firefox */
  * {
    scrollbar-width: thin;
    scrollbar-color: var(--scrollbar-thumb) var(--scrollbar-track);
  }

  @keyframes blink {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0;
    }
  }

  .cursor-blink {
    animation: blink 1s step-end infinite;
  }
</style>
